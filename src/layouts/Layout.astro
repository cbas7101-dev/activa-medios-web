---
import Header from '../components/Header.tsx';
import WhatsAppButton from '../components/WhatsAppButton.tsx';
import Footer from '../components/Footer.tsx';
import SeoHead from '../components/SeoHead.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, image, imageAlt } = Astro.props as Props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo-activa-medios.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead {title} {description} {image} {imageAlt} />
  </head>
  <body class="bg-black text-white m-0 p-0 overflow-x-hidden">
    <Header client:load />
    <slot />
    <WhatsAppButton client:load />
    <Footer client:load />
  </body>
</html>
